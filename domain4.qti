            <render_choice>
              <response_label ident="a"><material><mattext>Multiple failed login attempts</mattext></material></response_label>
              <response_label ident="b"><material><mattext>Successful data backup</mattext></material></response_label>
              <response_label ident="c"><material><mattext>Detection of malware signatures</mattext></material></response_label>
              <response_label ident="d"><material><mattext>Unusual outbound traffic</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition>
            <conditionvar>
              <and>
                <varequal respident="response24">a</varequal>
                <varequal respident="response24">c</varequal>
                <varequal respident="response24">d</varequal>
              </and>
              <not>
                <varequal respident="response24">b</varequal>
              </not>
            </conditionvar>
            <setvar varname="SCORE" action="Set">2</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <!-- MAQ 25 -->
      <item title="Question 25" ident="q25">
        <presentation>
          <material>
            <mattext>Which are critical steps in user deprovisioning? (Select all that apply)</mattext>
          </material>
          <response_lid ident="response25" rcardinality="Multiple">
            <render_choice>
              <response_label ident="a"><material><mattext>Disabling user accounts</mattext></material></response_label>
              <response_label ident="b"><material><mattext>Revoking access to systems and data</mattext></material></response_label>
              <response_label ident="c"><material><mattext>Granting admin rights</mattext></material></response_label>
              <response_label ident="d"><material><mattext>Removing user credentials from group memberships</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition>
            <conditionvar>
              <and>
                <varequal respident="response25">a</varequal>
                <varequal respident="response25">b</varequal>
                <varequal respident="response25">d</varequal>
              </and>
              <not>
                <varequal respident="response25">c</varequal>
              </not>
            </conditionvar>
            <setvar varname="SCORE" action="Set">2</setvar>
          </respcondition>
        </resprocessing>
      </item>
    </section>
  </assessment>
</questestinterop>
