      <!-- MAQ 16 -->
      <item title="Question 16" ident="q16">
        <presentation>
          <material>
            <mattext>Which of the following are examples of secure baseline requirements for servers? (Select all that apply)</mattext>
          </material>
          <response_lid ident="response16" rcardinality="Multiple">
            <render_choice>
              <response_label ident="a"><material><mattext>Disabling unused ports and services</mattext></material></response_label>
              <response_label ident="b"><material><mattext>Allowing default passwords</mattext></material></response_label>
              <response_label ident="c"><material><mattext>Applying latest security patches</mattext></material></response_label>
              <response_label ident="d"><material><mattext>Enabling host-based firewalls</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition>
            <conditionvar>
              <and>
                <varequal respident="response16">a</varequal>
                <varequal respident="response16">c</varequal>
                <varequal respident="response16">d</varequal>
              </and>
              <not>
                <varequal respident="response16">b</varequal>
              </not>
            </conditionvar>
            <setvar varname="SCORE" action="Set">2</setvar>
          </respcondition>
        </resprocessing>
      </item>
