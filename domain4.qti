<?xml version="1.0" encoding="UTF-8"?>
<questestinterop>
  <assessment title="Security+ SY0-701 Domain 4: Security Operations Practice">
    <section ident="root_section">
      <!-- MCQ 1 -->
      <item title="Question 1" ident="q1">
        <presentation>
          <material>
            <mattext>What is the primary purpose of establishing a secure baseline for computing resources?</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice>
              <response_label ident="a"><material><mattext>Simplify user onboarding</mattext></material></response_label>
              <response_label ident="b"><material><mattext>Ensure consistent security configurations</mattext></material></response_label>
              <response_label ident="c"><material><mattext>Increase network speed</mattext></material></response_label>
              <response_label ident="d"><material><mattext>Reduce compliance requirements</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition continue="No">
            <conditionvar><varequal respident="response1">b</varequal></conditionvar>
            <setvar varname="SCORE" action="Set">1</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <!-- MCQ 2 -->
      <item title="Question 2" ident="q2">
        <presentation>
          <material>
            <mattext>Which process best describes the removal of unnecessary services and features from a new server before it is deployed?</mattext>
          </material>
          <response_lid ident="response2" rcardinality="Single">
            <render_choice>
              <response_label ident="a"><material><mattext>Patch management</mattext></material></response_label>
              <response_label ident="b"><material><mattext>Tokenization</mattext></material></response_label>
              <response_label ident="c"><material><mattext>Hardening</mattext></material></response_label>
              <response_label ident="d"><material><mattext>Segmentation</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition continue="No">
            <conditionvar><varequal respident="response2">c</varequal></conditionvar>
            <setvar varname="SCORE" action="Set">1</setvar>
          </respcondition>
        </resprocessing>
      </item>
