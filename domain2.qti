          <material><mattext>Which of the following mitigation techniques involves the encryption of data to protect its confidentiality?</mattext></material>
          <response_lid ident="response22" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>Encryption</mattext></material></response_label>
