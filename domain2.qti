<?xml version="1.0" encoding="UTF-8"?>
<questestinterop>
  <assessment title="Security+ Domain 2: Threats, Vulnerabilities, and Mitigations">
    <section>
      <!-- Question 1 -->
      <item title="1" ident="1">
        <presentation>
          <material><mattext>Which of the following is a common motivation for nation-state threat actors?</mattext></material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>Financial gain</mattext></material></response_label>
              <response_label ident="B"><material><mattext>Espionage</mattext></material></response_label>
              <response_label ident="C"><material><mattext>Accidental damage</mattext></material></response_label>
              <response_label ident="D"><material><mattext>Personal vendetta</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition>
            <conditionvar><varequal respident="response1">B</varequal></conditionvar>
            <setvar>100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <!-- Question 2 -->
      <item title="2" ident="2">
        <presentation>
          <material><mattext>What is a common vector used in phishing attacks?</mattext></material>
          <response_lid ident="response2" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>Email</mattext></material></response_label>
              <response_label ident="B"><material><mattext>Physical access</mattext></material></response_label>
              <response_label ident="C"><material><mattext>Firewall exploitation</mattext></material></response_label>
              <response_label ident="D"><material><mattext>Malware injection</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition>
            <conditionvar><varequal respident="response2">A</varequal></conditionvar>
            <setvar>100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <!-- Question 3 -->
      <item title="3" ident="3">
        <presentation>
          <material><mattext>Which attack exploits a buffer overflow vulnerability?</mattext></material>
          <response_lid ident="response3" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>SQL injection</mattext></material></response_label>
              <response_label ident="B"><material><mattext>Race condition</mattext></material></response_label>
              <response_label ident="C"><material><mattext>Memory injection</mattext></material></response_label>
              <response_label ident="D"><material><mattext>XSS attack</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition>
            <conditionvar><varequal respident="response3">C</varequal></conditionvar>
            <setvar>100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <!-- Question 4 -->
      <item title="4" ident="4">
        <presentation>
          <material><mattext>What indicator may suggest that a user account is being targeted by a brute force attack?</mattext></material>
          <response_lid ident="response4" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>Increased CPU usage</mattext></material></response_label>
              <response_label ident="B"><material><mattext>Account lockout</mattext></material></response_label>
              <response_label ident="C"><material><mattext>Resource inaccessibility</mattext></material></response_label>
              <response_label ident="D"><material><mattext>Delayed network traffic</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition>
            <conditionvar><varequal respident="response4">B</varequal></conditionvar>
            <setvar>100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <!-- Question 5 -->
      <item title="5" ident="5">
        <presentation>
          <material><mattext>Which mitigation technique is designed to restrict software from running except those explicitly allowed?</mattext></material>
          <response_lid ident="response5" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>Segmentation</mattext></material></response_label>
              <response_label ident="B"><material><mattext>Application allow listing</mattext></material></response_label>
              <response_label ident="C"><material><mattext>Encryption</mattext></material></response_label>
              <response_label ident="D"><material><mattext>Isolation</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition>
            <conditionvar><varequal respident="response5">B</varequal></conditionvar>
            <setvar>100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <!-- Question 6 -->
      <item title="6" ident="6">
        <presentation>
          <material><mattext>Who is considered an insider threat?</mattext></material>
          <response_lid ident="response6" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>External hacker</mattext></material></response_label>
              <response_label ident="B"><material><mattext>Disgruntled employee</mattext></material></response_label>
              <response_label ident="C"><material><mattext>Cybercriminal group</mattext></material></response_label>
              <response_label ident="D"><material><mattext>Nation-state actor</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition>
            <conditionvar><varequal respident="response6">B</varequal></conditionvar>
            <setvar>100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <!-- Question 7 -->
      <item title="7" ident="7">
        <presentation>
          <material><mattext>What type of attack does 'watering hole' refer to?</mattext></material>
          <response_lid ident="response7" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>Network attack</mattext></material></response_label>
              <response_label ident="B"><material><mattext>Supply chain attack</mattext></material></response_label>
              <response_label ident="C"><material><mattext>Social engineering</mattext></material></response_label>
              <response_label ident="D"><material><mattext>Physical attack</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition>
            <conditionvar><varequal respident="response7">C</varequal></conditionvar>
            <setvar>100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <!-- Question 8 -->
      <item title="8" ident="8">
        <presentation>
          <material><mattext>Which of the following is an example of an attack surface?</mattext></material>
          <response_lid ident="response8" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>Open service ports</mattext></material></response_label>
              <response_label ident="B"><material><mattext>Threat actor motivation</mattext></material></response_label>
              <response_label ident="C"><material><mattext>Encryption keys</mattext></material></response_label>
              <response_label ident="D"><material><mattext>Security policy</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition>
            <conditionvar><varequal respident="response8">A</varequal></conditionvar>
            <setvar>100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <!-- Question 9 -->
      <item title="9" ident="9">
        <presentation>
          <material><mattext>What type of vulnerability involves an attacker exploiting the timing of operations?</mattext></material>
          <response_lid ident="response9" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>Zero-day</mattext></material></response_label>
              <response_label ident="B"><material><mattext>Race condition</mattext></material></response_label>
              <response_label ident="C"><material><mattext>Firmware vulnerability</mattext></material></response_label>
              <response_label ident="D"><material><mattext>Misconfiguration</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition>
            <conditionvar><varequal respident="response9">B</varequal></conditionvar>
            <setvar>100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <!-- Question 10 -->
      <item title="10" ident="10">
        <presentation>
          <material><mattext>What is the purpose of segmentation in network security?</mattext></material>
          <response_lid ident="response10" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>To separate networks to limit attack spread</mattext></material></response_label>
              <response_label ident="B"><material><mattext>To increase bandwidth</mattext></material></response_label>
              <response_label ident="C"><material><mattext>To simplify configurations</mattext></material></response_label>
              <response_label ident="D"><material><mattext>To monitor user activity</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition>
            <conditionvar><varequal respident="response10">A</varequal></conditionvar>
            <setvar>100</setvar>
          </respcondition>
        </resprocessing>
      </item>
