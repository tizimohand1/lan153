      <!-- Question 25 -->
      <item title="25" ident="25">
        <presentation>
          <material><mattext>Which endpoint protection method involves detecting and preventing host-based intrusions?</mattext></material>
          <response_lid ident="response25" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>Host-based firewall</mattext></material></response_label>
              <response_label ident="B"><material><mattext>HIPS</mattext></material></response_label>
              <response_label ident="C"><material><mattext>Application allow listing</mattext></material></response_label>
