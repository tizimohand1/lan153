      <item title="17" ident="17">
        <presentation>
          <material><mattext>Which of the following methods helps to secure enterprise applications by ensuring only authorized interactions?</mattext></material>
          <response_lid ident="response17" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>Isolation</mattext></material></response_label>
              <response_label ident="B"><material><mattext>Open ports</mattext></material></response_label>
              <response_label ident="C"><material><mattext>Default credentials</mattext></material></response_label>
              <response_label ident="D"><material><mattext>Supply chain integration</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition>
            <conditionvar><varequal respident="response17">A</varequal></conditionvar>
            <setvar>100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <!-- Question 18 -->
      <item title="18" ident="18">
        <presentation>
          <material><mattext>Which vulnerability type is frequently caused by misconfigurations?</mattext></material>
          <response_lid ident="response18" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>Cryptographic weakness</mattext></material></response_label>
              <response_label ident="B"><material><mattext>Misconfiguration</mattext></material></response_label>
              <response_label ident="C"><material><mattext>Memory injection</mattext></material></response_label>
              <response_label ident="D"><material><mattext>Social engineering</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition>
            <conditionvar><varequal respident="response18">B</varequal></conditionvar>
            <setvar>100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <!-- Question 19 -->
      <item title="19" ident="19">
        <presentation>
          <material><mattext>What kind of attack attempts to gain access by guessing or cracking passwords?</mattext></material>
          <response_lid ident="response19" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>Password spraying</mattext></material></response_label>
              <response_label ident="B"><material><mattext>SQL injection</mattext></material></response_label>
              <response_label ident="C"><material><mattext>DNS poisoning</mattext></material></response_label>
              <response_label ident="D"><material><mattext>DDoS</mattext></material></response_label>
