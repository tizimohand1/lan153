      <item title="24" ident="24">
        <presentation>
          <material><mattext>What is the advantage of decommissioning outdated systems?</mattext></material>
          <response_lid ident="response24" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>Reduces attack surface</mattext></material></response_label>
              <response_label ident="B"><material><mattext>Improves network speed</mattext></material></response_label>
              <response_label ident="C"><material><mattext>Increases monitoring</mattext></material></response_label>
