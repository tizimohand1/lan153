      <item title="11" ident="11">
        <presentation>
          <material><mattext>Which of the following is a social engineering technique that impersonates a trusted brand?</mattext></material>
          <response_lid ident="response11" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>Typosquatting</mattext></material></response_label>
              <response_label ident="B"><material><mattext>Vishing</mattext></material></response_label>
              <response_label ident="C"><material><mattext>Phishing</mattext></material></response_label>
              <response_label ident="D"><material><mattext>Smishing</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition>
            <conditionvar><varequal respident="response11">A</varequal></conditionvar>
            <setvar>100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <!-- Question 12 -->
      <item title="12" ident="12">
        <presentation>
          <material><mattext>Which of the following is a hardware vulnerability commonly addressed in enterprise security?</mattext></material>
          <response_lid ident="response12" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>End-of-life systems</mattext></material></response_label>
              <response_label ident="B"><material><mattext>SQL injection</mattext></material></response_label>
              <response_label ident="C"><material><mattext>DNS attacks</mattext></material></response_label>
              <response_label ident="D"><material><mattext>Race condition</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition>
            <conditionvar><varequal respident="response12">A</varequal></conditionvar>
