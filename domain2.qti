      <item title="16" ident="16">
        <presentation>
          <material><mattext>What kind of attack involves stealing cryptographic keys or breaking cryptographic algorithms?</mattext></material>
          <response_lid ident="response16" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>Cryptographic attack</mattext></material></response_label>
              <response_label ident="B"><material><mattext>Application attack</mattext></material></response_label>
              <response_label ident="C"><material><mattext>Network attack</mattext></material></response_label>
              <response_label ident="D"><material><mattext>Physical attack</mattext></material></response_label>
