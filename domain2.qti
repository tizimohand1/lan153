          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition>
            <conditionvar><varequal respident="response19">A</varequal></conditionvar>
            <setvar>100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <!-- Question 20 -->
      <item title="20" ident="20">
        <presentation>
          <material><mattext>In risk mitigation, what is the purpose of patching?</mattext></material>
          <response_lid ident="response20" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>To monitor network activity</mattext></material></response_label>
              <response_label ident="B"><material><mattext>To fix vulnerabilities</mattext></material></response_label>
              <response_label ident="C"><material><mattext>To segment the network</mattext></material></response_label>
              <response_label ident="D"><material><mattext>To isolate infected systems</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition>
            <conditionvar><varequal respident="response20">B</varequal></conditionvar>
            <setvar>100</setvar>
          </respcondition>
        </resprocessing>
