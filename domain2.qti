      <!-- Question 13 -->
      <item title="13" ident="13">
        <presentation>
          <material><mattext>What type of attack is characterized by attempts to overwhelm services with traffic?</mattext></material>
          <response_lid ident="response13" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>DDoS</mattext></material></response_label>
              <response_label ident="B"><material><mattext>Ransomware</mattext></material></response_label>
              <response_label ident="C"><material><mattext>Trojan</mattext></material></response_label>
              <response_label ident="D"><material><mattext>Worm</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition>
            <conditionvar><varequal respident="response13">A</varequal></conditionvar>
            <setvar>100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <!-- Question 14 -->
      <item title="14" ident="14">
        <presentation>
          <material><mattext>Which mitigation approach uses the principle of least privilege?</mattext></material>
          <response_lid ident="response14" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>Access control</mattext></material></response_label>
              <response_label ident="B"><material><mattext>Encryption</mattext></material></response_label>
              <response_label ident="C"><material><mattext>Patching</mattext></material></response_label>
              <response_label ident="D"><material><mattext>Continuous monitoring</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition>
            <conditionvar><varequal respident="response14">A</varequal></conditionvar>
            <setvar>100</setvar>
          </respcondition>
        </resprocessing>
      </item>
      <!-- Question 15 -->
      <item title="15" ident="15">
        <presentation>
          <material><mattext>Which of the following describes a zero-day vulnerability?</mattext></material>
          <response_lid ident="response15" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>Known vulnerability with a patch available</mattext></material></response_label>
              <response_label ident="B"><material><mattext>Unknown vulnerability not yet exploited</mattext></material></response_label>
              <response_label ident="C"><material><mattext>Unknown vulnerability being exploited before public awareness</mattext></material></response_label>
              <response_label ident="D"><material><mattext>An intentional backdoor</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition>
            <conditionvar><varequal respident="response15">C</varequal></conditionvar>
            <setvar>100</setvar>
          </respcondition>
        </resprocessing>
      </item>
