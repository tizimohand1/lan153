      <!-- Question 23 -->
      <item title="23" ident="23">
        <presentation>
          <material><mattext>Which is the best way to monitor for unusual activity on an enterprise network?</mattext></material>
          <response_lid ident="response23" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>Regular patching</mattext></material></response_label>
              <response_label ident="B"><material><mattext>Encryption</mattext></material></response_label>
              <response_label ident="C"><material><mattext>Continuous monitoring</mattext></material></response_label>
