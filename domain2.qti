          <material><mattext>What is the primary security concern with using default credentials on devices?</mattext></material>
          <response_lid ident="response21" rcardinality="Single">
            <render_choice>
              <response_label ident="A"><material><mattext>They are widely known and exploited</mattext></material></response_label>
              <response_label ident="B"><material><mattext>They cause configuration errors</mattext></material></response_label>
              <response_label ident="C"><material><mattext>They improve convenience</mattext></material></response_label>
              <response_label ident="D"><material><mattext>They prevent updates</mattext></material></response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <respcondition>
            <conditionvar><varequal respident="response21">A</varequal></conditionvar>
            <setvar>100</setvar>
          </respcondition>
        </resprocessing>
      </item>
