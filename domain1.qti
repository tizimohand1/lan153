    <!-- Question 5: Multiple Choice -->
    <item title="Non-repudiation ensures what?" ident="q5">
      <presentation>
        <material>
          <mattext>Non-repudiation ensures what?</mattext>
        </material>
        <response_lid ident="response5">
          <render_choice>
            <response_label ident="A"><material><mattext>Data remains confidential</mattext></material></response_label>
            <response_label ident="B"><material><mattext>The origin of a message can be verified</mattext></material></response_label>
            <response_label ident="C"><material><mattext>Data is always available</mattext></material></response_label>
            <response_label ident="D"><material><mattext>Only authorized users can access data</mattext></material></response_label>
          </render_choice>
        </response_lid>
      </presentation>
      <resprocessing>
        <respcondition>
          <conditionvar>
            <varequal respident="response5">B</varequal>
          </conditionvar>
          <setvar action="Set">100</setvar>
        </respcondition>
