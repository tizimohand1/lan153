<?xml version="1.0" encoding="UTF-8"?>
<questestinterop>
  <assessment title="CompTIA Security+ SY0-701 Domain 1: General Security Concepts">
    <!-- Question 1: Multiple Choice -->
    <item title="What does the CIA triad stand for?" ident="q1">
      <presentation>
        <material>
          <mattext>What does the CIA triad stand for?</mattext>
        </material>
        <response_lid ident="response1">
          <render_choice>
            <response_label ident="A"><material><mattext>Confidentiality, Integrity, Availability</mattext></material></response_label>
            <response_label ident="B"><material><mattext>Control, Input, Authentication</mattext></material></response_label>
            <response_label ident="C"><material><mattext>Cryptography, Identity, Access</mattext></material></response_label>
            <response_label ident="D"><material><mattext>Control, Integrity, Audit</mattext></material></response_label>
          </render_choice>
        </response_lid>
      </presentation>
      <resprocessing>
        <respcondition>
          <conditionvar>
            <varequal respident="response1">A</varequal>
          </conditionvar>
          <setvar action="Set">100</setvar>
        </respcondition>
      </resprocessing>
    </item>
    <!-- Question 2: Multiple Choice -->
    <item title="Which of the following is an example of a technical security control?" ident="q2">
      <presentation>
        <material>
          <mattext>Which of the following is an example of a technical security control?</mattext>
        </material>
        <response_lid ident="response2">
          <render_choice>
            <response_label ident="A"><material><mattext>Security Policy</mattext></material></response_label>
            <response_label ident="B"><material><mattext>CCTV Surveillance</mattext></material></response_label>
            <response_label ident="C"><material><mattext>Firewall</mattext></material></response_label>
            <response_label ident="D"><material><mattext>Security Awareness Training</mattext></material></response_label>
          </render_choice>
        </response_lid>
      </presentation>
      <resprocessing>
        <respcondition>
          <conditionvar>
            <varequal respident="response2">C</varequal>
          </conditionvar>
          <setvar action="Set">100</setvar>
        </respcondition>
      </resprocessing>
    </item>
    <!-- Question 3: Multiple Choice -->
    <item title="What is the concept of 'least privilege'?" ident="q3">
      <presentation>
        <material>
          <mattext>What is the concept of 'least privilege'?</mattext>
        </material>
        <response_lid ident="response3">
          <render_choice>
            <response_label ident="A"><material><mattext>Giving users access to all company resources</mattext></material></response_label>
            <response_label ident="B"><material><mattext>Providing each user only the permissions needed to do their job</mattext></material></response_label>
            <response_label ident="C"><material><mattext>Assigning all users the same role</mattext></material></response_label>
            <response_label ident="D"><material><mattext>Requiring two people for every decision</mattext></material></response_label>
          </render_choice>
        </response_lid>
      </presentation>
      <resprocessing>
        <respcondition>
          <conditionvar>
            <varequal respident="response3">B</varequal>
          </conditionvar>
          <setvar action="Set">100</setvar>
        </respcondition>
      </resprocessing>
    </item>
