<?xml version="1.0" encoding="UTF-8"?>
<questestinterop>
  <!-- 1 -->
  <item ident="q1" title="Question 1">
    <presentation>
      <material><mattext>Which architecture model involves shared security responsibilities between the cloud provider and the customer?</mattext></material>
      <response_lid ident="response1" rcardinality="Single">
        <render_choice>
          <response_label ident="A"><material><mattext>On-premises architecture</mattext></material></response_label>
          <response_label ident="B"><material><mattext>Cloud architecture</mattext></material></response_label>
          <response_label ident="C"><material><mattext>Zero-trust architecture</mattext></material></response_label>
          <response_label ident="D"><material><mattext>Decentralized architecture</mattext></material></response_label>
        </render_choice>
      </response_lid>
    </presentation>
    <resprocessing>
      <outcomes>
        <decvar varname="SCORE" vartype="Decimal" minvalue="0" maxvalue="1"/>
      </outcomes>
      <respcondition continue="No">
        <conditionvar><varequal respident="response1">B</varequal></conditionvar>
        <setvar varname="SCORE" action="Set">1</setvar>
      </respcondition>
    </resprocessing>
  </item>

  <!-- 2 -->
  <item ident="q2" title="Question 2">
    <presentation>
      <material><mattext>What is an essential characteristic to consider in designing resilient architectures?</mattext></material>
      <response_lid ident="response1" rcardinality="Single">
        <render_choice>
          <response_label ident="A"><material><mattext>Single point of failure</mattext></material></response_label>
          <response_label ident="B"><material><mattext>Lack of redundancy</mattext></material></response_label>
          <response_label ident="C"><material><mattext>High availability</mattext></material></response_label>
          <response_label ident="D"><material><mattext>Manual failover processes</mattext></material></response_label>
        </render_choice>
      </response_lid>
    </presentation>
    <resprocessing>
      <outcomes>
        <decvar varname="SCORE" vartype="Decimal" minvalue="0" maxvalue="1"/>
      </outcomes>
      <respcondition continue="No">
        <conditionvar><varequal respident="response1">C</varequal></conditionvar>
        <setvar varname="SCORE" action="Set">1</setvar>
      </respcondition>
    </resprocessing>
  </item>

