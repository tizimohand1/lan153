      <material><mattext>Which items are considered when applying security principles to enterprise infrastructure? (Select all that apply.)</mattext></material>
      <response_lid ident="response1" rcardinality="Multiple">
        <render_choice>
          <response_label ident="A"><material><mattext>Attack surface</mattext></material></response_label>
          <response_label ident="B"><material><mattext>Security zones</mattext></material></response_label>
          <response_label ident="C"><material><mattext>Firewall placement</mattext></material></response_label>
          <response_label ident="D"><material><mattext>Data sovereignty</mattext></material></response_label>
        </render_choice>
      </response_lid>
    </presentation>
    <resprocessing>
      <outcomes>
        <decvar varname="SCORE" vartype="Decimal" minvalue="0" maxvalue="1"/>
      </outcomes>
      <respcondition continue="No">
        <conditionvar>
          <and>
            <varequal respident="response1">A</varequal>
            <varequal respident="response1">B</varequal>
            <varequal respident="response1">C</varequal>
          </and>
        </conditionvar>
        <setvar varname="SCORE" action="Set">1</setvar>
      </respcondition>
    </resprocessing>
  </item>

