      <material><mattext>Which security principle focuses on limiting access rights for users to the minimum necessary?</mattext></material>
      <response_lid ident="response1" rcardinality="Single">
        <render_choice>
          <response_label ident="A"><material><mattext>Least privilege</mattext></material></response_label>
          <response_label ident="B"><material><mattext>Separation of duties</mattext></material></response_label>
          <response_label ident="C"><material><mattext>Defense in depth</mattext></material></response_label>
          <response_label ident="D"><material><mattext>Fail-safe defaults</mattext></material></response_label>
        </render_choice>
      </response_lid>
    </presentation>
