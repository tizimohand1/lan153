            <response_label ident="c"><material><mattext>GDPR</mattext></material></response_label>
            <response_label ident="d"><material><mattext>SOX</mattext></material></response_label>
          </render_choice>
        </response_lid>
      </presentation>
      <resprocessing>
        <respcondition>
          <conditionvar><varequal respident="response2">a</varequal></conditionvar>
          <setvar varname="SCORE" action="Set">1</setvar>
        </respcondition>
      </resprocessing>
    </item>
