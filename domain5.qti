<?xml version="1.0" encoding="UTF-8"?>
<questestinterop>
  <assessment title="Security+ SY0-701 Domain 5 Practice">

    <!-- Multiple Choice Questions -->
    <item title="Security policy documentation" ident="q1">
      <presentation>
        <material><mattext>Which document typically defines an organization's security requirements and high-level goals?</mattext></material>
        <response_lid ident="response1">
          <render_choice>
            <response_label ident="a"><material><mattext>Security policy</mattext></material></response_label>
            <response_label ident="b"><material><mattext>Security baseline</mattext></material></response_label>
            <response_label ident="c"><material><mattext>Audit log</mattext></material></response_label>
            <response_label ident="d"><material><mattext>Awareness training</mattext></material></response_label>
          </render_choice>
        </response_lid>
      </presentation>
      <resprocessing>
        <respcondition>
          <conditionvar><varequal respident="response1">a</varequal></conditionvar>
          <setvar varname="SCORE" action="Set">1</setvar>
        </respcondition>
      </resprocessing>
    </item>
    <item title="Security frameworks" ident="q2">
